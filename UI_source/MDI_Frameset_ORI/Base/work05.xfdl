    <Script type="xscript5.1"><![CDATA[
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrPopFrame = nexacro.getPopupFrames();
	if(arrPopFrame.length > 0 ) {
		for (var i=0; i<arrPopFrame.length; i++) {			
			trace(arrPopFrame[i].id);
			if (arrPopFrame[i].id == "modeless01") {
				arrPopFrame[i].form.setFocus();
				return;
			}
		}
		
	}
	
	nexacro.open("modeless01", "Base::test_pop.xfdl", this.getOwnerFrame(),{}, "showtitlebar=true resizable=true", 0, 0, 690, 450, this);		
};

this.Button02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
