this.Button04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrPopFrame = nexacro.getPopupFrames();
	var arrLen = arrPopFrame.length;
	if(arrLen > 0 ) {
		for (var i=0; i<arrLen; i++) {			
				trace(arrPopFrame[0].id);
				// 삭제시 배열도 전부 동적으로 바뀌기에 3개 띄워놓으면 3번 삭제 
				arrPopFrame[0].form.close();							
		}		
	}
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrPopFrame = nexacro.getPopupFrames();
	if(arrPopFrame.length > 0 ) {
		for (var i=0; i<arrPopFrame.length; i++) {			
			trace(arrPopFrame[i].id);
			if (arrPopFrame[i].id == "modeless01") {
				arrPopFrame[i].form.Button00.click();
				return;
			}
		}
		
	}
};

this.btn_pop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//showmodal		
	//this.lfn_Dialog("frmpop01", "Base::np_Form_Showmodal_Popup.xfdl", "123", 0, 0, 400, 551, true, "f_pop_callback");		
	this.lfn_Dialog("frmpop01", "Base::test_pop.xfdl", "123", 0, 0, 400, 551, true, "f_pop_callback");		
};

this.lfn_Dialog = function (sFormId, sUrl, sArg, nLeft, nTop, nWidth, nHeight, bModeless, sCallbackFunc)
{
	
	var newChild = null;
	var objParentFrame = this.getOwnerFrame();

	newChild = new ChildFrame();
	newChild.init(sFormId, 0, 0, nWidth, nHeight, null, null, sUrl);
	newChild.set_openalign("center middle");	
	newChild.set_resizable(true);	
	newChild.set_topmost(true);	
	newChild.showModal(sFormId,objParentFrame, {pv_arg:sArg}, this, sCallbackFunc);
	
	// showModal 호출 이후 로직 처리시 어싱크로 처리 된다.
	// 즉, showModal 팝업 띄우면서 아래의 trace 스크립트 구문 로직 실행 	
	trace("모달 팝업 호출하면서 스클립트 실행");
	// 모달 팝업 닫힌 후 싱크방식으로 처리 하기 위해서는 callbackfunc 에서 스크립트작성
};
this.f_pop_callback=function(v1,v2)
{
	this.Edit00.set_value(v1 + " / " + v2);
	
	if (v2 == "aa") {
		trace("aa");
		// 모달 팝업 닫힌 후 값에 따라 로직 작성
	} else if (v2 == "bb") {
		trace("bb");	
		// 모달 팝업 닫힌 후 값에 따라 로직 작성
	}	
	
};



this.btn_open_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrPopFrame = nexacro.getPopupFrames();
	if(arrPopFrame.length > 0 ) {
		for (var i=0; i<arrPopFrame.length; i++) {			
			trace(arrPopFrame[i].id);
			if (arrPopFrame[i].id == "modeless01") {
				arrPopFrame[i].form.setFocus();
				return;
			}
		}
		
	}
	
	nexacro.open("modeless01", "Base::test_pop.xfdl", this.getOwnerFrame(),{}, "showtitlebar=true resizable=true", 0, 0, 690, 450, this);		
	//nexacro.open("modeless01", "Base::test_pop.xfdl", null,{}, "showtitlebar=true resizable=true", 0, 0, 690, 450, this);		
	
};

this.Button20_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("\n=========== Environment=================");
	trace("\Environment.themeid : " + nexacro.getEnvironment().themeid);
