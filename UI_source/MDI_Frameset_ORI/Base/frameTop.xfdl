            <Col id="PARENT_ID">CL</Col>
            <Col id="TOP_PARENT_ID">CL</Col>
            <Col id="MENU_NM">CleanLine조회접수</Col>
            <Col id="DEPTH">1</Col>
            <Col id="APP_GROUP">comg</Col>
            <Col id="PROG_ID">CLMGAA010</Col>
            <Col id="MENU_TYPE">P</Col>
            <Col id="AUTH">10000000</Col>
            <Col id="INNER_PARAM"/>
            <Col id="MENU_NAVI">|CleanLine|CleanLine조회접수</Col>
            <Col id="PROG_FILE">CLMGAA010</Col>
