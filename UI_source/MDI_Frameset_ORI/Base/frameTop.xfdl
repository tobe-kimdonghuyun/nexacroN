      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**********************************************************************************************
 * 01. 업무구분	: Frame
 * 02. 화면		: frameTop.xfdl
 * 03. 화면설명	: frame Top
 * 04. 관련화면/서비스 : 
 * 05. 수정이력	: 
 **********************************************************************************************
 *  수정일     	이  름   	사유 
 **********************************************************************************************
 *  2024-12-30	TOBESOFT  	최초작성
 **********************************************************************************************
*/
/*******************************************************************************************************************************
 * FORM 변수 선언 영역
*******************************************************************************************************************************/
this.fv_firstGap 		= 0;		// 첫 메뉴버튼 위치 여백
this.fv_btnGap 			= 7;
this.fv_btnHeight 		= 42;
this.fv_topBtnPrefix 	= "";

this.fv_eisAuthKey = "";

this.objApp = nexacro.getApplication();
this.zoomScale = 100;
this.fv_isMenuActive = false;		// 메뉴가 클릭되어 열린 상태인지 체크하는 변수
/*******************************************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose..)
*******************************************************************************************************************************/
/**
 * @description 화면 오픈
 */
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// TopFrame 로드 후 LEFT Frame 로드
	//nexacro.getApplication().agv_frame_leftmenu.formurl = "frame::frameLeft.xfdl";
	this.divTopBtn.form.set_scrollbartype("none");
	this.fn_setTopMenu();
	
	// 팝업 메뉴(menTop)에 마우스 인/아웃 이벤트 동적 연결
    this.menTop.addEventHandler("onmouseenter", this.menTop_onmouseenter, this);
    this.menTop.addEventHandler("onmouseleave", this.menTop_onmouseleave, this);
	this.menTop.addEventHandler("oninnerpopup", this.menTop_oninnerpopup, this);
	
};

this.form_ontimer = function(obj, e)
{
	// 세션타이머 처리 결과 확인
	if (e.timerid == 2) {
		this.fn_getSessionConnectYn();
	}
	// 메뉴 자동 닫기 타이머 (99번)
	else if (e.timerid == 99) {
		this.killTimer(99);
		
		// 하위 메뉴 팝업 닫기
		if (this.menTop.isPopup()) {
			this.menTop.cancelPopup();
		}
		
		// 대메뉴 버튼 CSS 원상복구
		this.fn_setActiveBtn(""); 

		// 메뉴가 완전히 닫혔으므로 상태 초기화 (다시 클릭해야만 열리도록)
		this.fv_isMenuActive = false; 
	} 
	else {
		this.killTimer(1);
		this.fn_move();
	}
};

/**
 * @description 화면 리사이징
 */
this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	// 메뉴버튼 Redraw
	this.fn_redrawBtn();
};
/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/
/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/
//message
this.fn_msgCallback = function (sMsgId, sRtn)
{
	switch(sMsgId) {
		case "logout":
			if(sRtn=="false"||sRtn==false||this.gfn_isNull(sRtn)){
				return;
			}
			this.fn_logout("logout");
			break;
		case "initframe":
			if(sRtn){
				if ( nexacro.getApplication().agv_frame_mdiframe.frames.length < 1 )	return;
	
				// 열린화면 모두 닫기
				nexacro.getApplication().agv_frame_openlist.form.fn_noCheckCloseAll();
				
				// 좌측메뉴 재구성(첫번째 대메뉴로)
				//nexacro.getApplication().agv_frame_leftmenu.form.fn_setSubMenu(nexacro.getApplication().gdsMenu.getColumn(0,"MENU_ID"));
				
				//if (nexacro.getApplication().gv_userTypeCd != "ETC") this.gfn_setMain();
			}
			break;
	}
};

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/
this.fn_setUserInfo = function()
{
	//사용자 정보 static 세팅
	var sUserNm = nexacro.getApplication().gv_empNm;
	var sUserInfo = sUserNm + "님";
	this.staUserInfo.set_text(sUserInfo);
	this.resetScroll();
};

/**
 * @description topmenu 셋팅
 */
this.fn_setTopMenu = function ()
{
	//this.gfn_log(this.objApp.gdsMenu.saveXML());
	
	// Top 메뉴 복사
	//this.objApp.gdsMenu.filter("DEPTH == '0'");
	//this.dsMenu.copyData(this.objApp.gdsMenu, true);
	//this.objApp.gdsMenu.filter("");
	
	for (var i = 0; i < this.dsMenu.getRowCount(); i++) 
	{
		var sMenuId = this.dsMenu.getColumn(i, "MENU_ID");
		var sMenuName = this.dsMenu.getColumn(i, "MENU_NM");
		
		this.fn_createTopMenu(sMenuId, sMenuName, i);
	}
	
	this.dsMenu.filter("");
	
	// 메뉴버튼 Redraw
	this.fn_redrawBtn();
};

/**
 * @description Top menu creation
 */
this.fn_createTopMenu = function (sTopId, sName, index)
{
	// Creating page button
	var objBtn = new Button();
	objBtn.init(this.fv_topBtnPrefix + sTopId, this.fn_getLeft(sTopId), 0, 130, this.fv_btnHeight, null, null);
	//objBtn.init(this.fv_topBtnPrefix + sTopId, 0, 0, 130, this.fv_btnHeight, null, null);
	this.divTopBtn.form.addChild(objBtn.name, objBtn);

	objBtn.set_text(sName);
	objBtn.set_cssclass("btn_TF_Menu");
	objBtn.menuid = sTopId;
	objBtn.show();
	
	// 버튼 width 셋팅
	objBtn.set_fittocontents("width");
	var nWidth = objBtn.getOffsetWidth();
	objBtn.set_fittocontents("none");
	objBtn.set_width(nWidth);
	
	//this.divTopBtn.form.resetScroll();
	
	objBtn.setEventHandler("onclick", this.btnTopMenu_onclick, this);
	objBtn.setEventHandler("onmouseenter", this.btnTopMenu_onmouseenter, this);	// 마우스 커서를 올렸을 때 이벤트 연결
	objBtn.setEventHandler("onmouseleave", this.btnTopMenu_onmouseleave, this);	// 마우스 커서가 버튼을 벗어났을 때 이벤트 연결
};

/**
 * @description 이전 버튼을 기준으로 버튼위치 리턴
 */
this.fn_getLeft = function (sTopId)
{
	var nCurRow = this.dsMenu.findRow("MENU_ID", sTopId);
	if (nCurRow == 0) return this.fv_firstGap;

	var objPrevTab = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(nCurRow - 1, "MENU_ID"));
	return objPrevTab.getOffsetRight() + this.fv_btnGap;
};

/**
 * @description Top 메뉴 click
 */
this.fn_menuClick = function(oBtnTop, sMenuId, sMenuNm)
{
	// 다른 메뉴를 열기 전에, 기존에 열려있던 팝업을 상세메뉴까지 완전히 닫아줌
	if (this.menTop.isPopup()) {
		this.menTop.cancelPopup();
	}

	// Top 메뉴 복사
	//this.pmnuSubMenu.trackPopupByComponent(oBtnTop,0,oBtnTop.getOffsetHeight() + 1);
	var nIdx = this.dsMenu.findRow("MENU_ID",sMenuId);
	

	
	this.menTop.left = this.divTopBtn.getOffsetLeft() + oBtnTop.getOffsetLeft();
	this.menTop.trackPopup(nIdx,0,1,false);

 
};

/**
 * @description 버튼 redraw 
 */
this.fn_redrawBtn = function ()
{
	// 모든 버튼 체크 
	this.fn_checkShowBtnAll();
	
	// spin 버튼 visible 처리
	//this.fn_setSpinBtnShow();
};

/**
 * @description 모든 버튼 체크 
 */
this.fn_checkShowBtnAll = function ()
{
	if (this.dsMenu.rowcount == 0) return;

	var objTopFirst = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(0, "MENU_ID"));
	var objTopLast = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(this.dsMenu.rowcount - 1, "MENU_ID"));

	var nLeft = objTopFirst.getOffsetLeft();
	var nRight = objTopLast.getOffsetRight();

	if (this.divTopBtn.getOffsetWidth() >= (nRight - nLeft)) 
	{
		this.fn_moveFirst(0);
		return;
	}
};

/**
 * @description menu tab 버튼 첫번째 이동 함수
 */
this.fn_moveFirst = function (nMoveIdx)
{
	var nIndex;
	var sTopId;
	var objTop;
	var objTopFirst;

	nIndex = this.fn_getFirstTopIndex();
	
	if (nIndex < 0) return;

	if (nMoveIdx < 0) return;

	if (nMoveIdx >= this.dsMenu.rowcount) return;

	sTopId = this.dsMenu.getColumn(nIndex, "MENU_ID");
	objTopFirst = this.fn_findObj(this.fv_topBtnPrefix + sTopId);

	sTopId = this.dsMenu.getColumn(nMoveIdx, "MENU_ID");
	objTop = this.fn_findObj(this.fv_topBtnPrefix + sTopId);
	
	var nShiftPos = objTop.getOffsetLeft() - objTopFirst.getOffsetLeft();
	for (var i = 0; i < this.dsMenu.rowcount; i++) 
	{
		sTopId = this.dsMenu.getColumn(i, "MENU_ID");
		objTop = this.fn_findObj(this.fv_topBtnPrefix + sTopId);
		objTop.move(objTop.getOffsetLeft() - nShiftPos, objTop.getOffsetTop());
	}
};

/**
 * @description menu top 버튼 첫번째 index 가져오는 함수
 */
this.fn_getFirstTopIndex = function ()
{
	for (var i=0; i < this.dsMenu.rowcount;i++)
	{
		var sTopID  = this.dsMenu.getColumn(i, "MENU_ID");
		var objTop = this.fn_findObj(this.fv_topBtnPrefix + sTopID);
		if (this.gfnIsNull(objTop) == false) 
		{
			if (0 <= objTop.getOffsetLeft()) return i;
		}
	}
	return -1;
};

/**
 * @description MDI spin 버튼 visible 처리
 */
this.fn_setSpinBtnShow = function ()
{
	var objTop;
	
	if (this.dsMenu.rowcount == 0) {		
		this.btnPre.set_visible(false);
		this.btnNext.set_visible(false);
		return;
	}

	objTop = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(this.dsMenu.rowcount - 1, "MENU_ID"));
	if (this.divTopBtn.getOffsetWidth() < objTop.getOffsetRight()) {
		this.btnNext.set_visible(true);
	} else {
		this.btnNext.set_visible(false);
	}

	objTop = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(0, "MENU_ID"));
	if (objTop.getOffsetLeft() < 0) {
		this.btnPre.set_visible(true);
	} else {
		this.btnPre.set_visible(false);
	}
};

/**
 * @description menu tab 찾는 함수
 */
this.fn_findObj = function (sId)
{
	return this.divTopBtn.form.components[sId];
};

/**
 * @description 메뉴버튼 활성화
 */
this.fn_setActiveBtn = function (sMenuId)
{
	var objMenu;
	
	for (var i = 0; i < this.dsMenu.getRowCount(); i++) 
	{
		objMenu = this.fn_findObj(this.fv_topBtnPrefix + this.dsMenu.getColumn(i, "MENU_ID"));
		if (sMenuId == this.dsMenu.getColumn(i, "MENU_ID")) {
			objMenu.set_cssclass("btn_TF_MenuAT");
		} else {
			objMenu.set_cssclass("btn_TF_Menu");
		}
	}
};

// 열려있는 화면의 Top Menu 표시
this.fn_setMenu = function(sTopMenuId, sMenuId)
{
	this.fn_setActiveBtn(sTopMenuId);
	
	var sMenuNm = this.dsMenu.lookup("MENU_ID",sTopMenuId,"MENU_NM");
	
	this.objApp.agv_frame_leftmenu.form.fn_setSubMenu(sTopMenuId, sMenuNm, sMenuId);
};

this.fn_getSessionConnectYn = function()
{
	if(nexacro.getApplication().gv_logOutCode == "Y" && nexacro.getApplication().gv_userId=="2080301"){
		this.fn_logout();
	}
};

/**
 * @class 로그아웃 실행 여부 확인 함수
 * @return {boolean} 로그아웃 실행 여부
 */
this.fn_preLogout = function(msgCd) {
	
	if (this.gfn_isNull(msgCd)) {
		// N-KIS를 종료 하시겠습니까?
		this.gfn_confirm("Common.C107","","","logout");
	} else {
		// 차세대 정보시스템을 로그아웃 하시겠습니까?
		this.gfn_confirm(msgCd,"","","logout");
	}
};

// 전체화면 설정
this.fn_openFullscreen = function()
{
	if (system.navigatorname == "nexacro") {
		this.objApp.mainframe.openstatus = "maximize";
	} else {
		var elem = document.documentElement;
		if (elem.requestFullscreen) {
			elem.requestFullscreen();
		} else if (elem.mozRequestFullScreen) { // Firefox
			elem.mozRequestFullScreen();
		} else if (elem.webkitRequestFullscreen) { // Chrome, Safari & Opera
			elem.webkitRequestFullscreen();
		} else if (elem.msRequestFullscreen) { // IE/Edge
			elem.msRequestFullscreen();
		}
	}
}

// 전체화면 해제
this.fn_closeFullscreen = function()
{
	if (system.navigatorname == "nexacro") {
		this.objApp.mainframe.openstatus = "normal";
	} else {
		if (document.exitFullscreen) {
			document.exitFullscreen();
		} else if (document.mozCancelFullScreen) { // Firefox
			document.mozCancelFullScreen();
		} else if (document.webkitExitFullscreen) { // Chrome, Safari & Opera
			document.webkitExitFullscreen();
		} else if (document.msExitFullscreen) { // IE/Edge
			document.msExitFullscreen();
		}
	}
}

// /*******************************************************************************************************************************
//  * 각 COMPONENT 별 EVENT 영역
// *******************************************************************************************************************************/
/**
 * @description 좌측메뉴 열고 닫기
 */
this.chkLfCtrl_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.value){
		this.gfn_hideLeftFrame();
	} else {	
		this.gfn_showLeftFrame();
	}
};
/**
 * @description Logo click
 */
this.staLogo_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 메인화면 호출
	this.gfn_setMain();
};

/**
 * @description Top 메뉴 버튼 click
 */
this.btnTopMenu_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.killTimer(99);
	this.fv_isMenuActive = true;

	var sMenuId = obj.menuid;
	if (this.gfnIsNull(sMenuId)) return;
	
	// 선택된 메뉴버튼 css 활성화
	this.fn_setActiveBtn(sMenuId);
	
	// Top 메뉴 click
	this.fn_menuClick(obj, sMenuId, obj.text);
}

/**
 * @description 메뉴 ◀ 버튼 click
 */
this.btnPre_onclick = function (obj:Button, e:ClickEventInfo)
{
	this.fn_moveFirst(this.fn_getFirstTopIndex() - 1);
	
	// 메뉴버튼 Redraw
	this.fn_redrawBtn();
};

/**
 * @description 메뉴 ▶ 버튼 click
 */
this.btnNext_onclick = function (obj:Button, e:ClickEventInfo)
{
	this.fn_moveFirst(this.fn_getFirstTopIndex() + 1);
	
	// 메뉴버튼 Redraw
	this.fn_redrawBtn();
};

/**
 * @description 팝업메뉴 클릭
 */
this.menTop_onmenuclick = function(obj:nexacro.Menu,e:nexacro.MenuClickEventInfo)
{
	// 좌측프레임 메뉴 열기
	nexacro.getApplication().agv_frame_leftmenu.form.fn_openLeftMenu(e.id);
};

/**
 * @description 전체화면 보기/해제 클릭
 */
this.chkScrCtrl_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.value){
		this.fn_openFullscreen();			// 전체화면 보기
	}else{	
		this.fn_closeFullscreen();			// 전체화면 해제
	}	
};

/**
 * @description MY정보 클릭 시 이벤트 함수
 */
this.staUserInfo_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.gfn_popup("CMSYUS020_P01", "cmsy::CMSYUS020_P01.xfdl", 553, 477);
	// this.gfn_popupModeless("CMSYUS020_P01", "cmsy::CMSYUS020_P01.xfdl", 553, 438);
};

/**
 * @class 로그아웃 클릭 시 이벤트 함수
 * @param {Static} obj Static Object
 * @param {ClickEventInfo} e 클릭 이벤트 정보
 * @return none
 */
this.btnLogout_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_preLogout();
};

/**
 * @class 로고 클릭 시 이벤트 함수
 * @param {ImageViewer} obj ImageViewer Object
 * @param {ClickEventInfo} e 클릭 이벤트 정보
 * @return none
 * @description 로그인 후 상태로 되돌리기
 */
this.imgLogo_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	this.gfn_confirm("","모든 창을 초기화 하시겠습니까? ","초기화","initframe");
};

/**
 * @description Top 메뉴 버튼에 마우스 올렸을 때
 */
this.btnTopMenu_onmouseenter = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.killTimer(99); // 숨바꼭질 방지용 타이머 취소

	// 최초 클릭을 해서 메뉴가 활성화된 상태일 때만 하위 메뉴를 염
	if (this.fv_isMenuActive == true) {
		// 현재 이미 열려있는 대메뉴 버튼이라면 작동 무시 (깜빡임 방지)
		if (obj.cssclass == "btn_TF_MenuAT") return;
	
		var sMenuId = obj.menuid;
		if (this.gfnIsNull(sMenuId)) return;
		
		this.fn_setActiveBtn(sMenuId);
		this.fn_menuClick(obj, sMenuId, obj.text);
	}
};

/**
 * @description 대메뉴 버튼에서 마우스가 벗어났을 때 (0.3초 대기 시작)
 */
this.btnTopMenu_onmouseleave = function(obj:nexacro.Button, e:nexacro.MouseEventInfo)
{
    this.setTimer(99, 300); // 300ms(0.3초) 후 닫기 시도
};

/**
 * @description 하위 팝업메뉴(menTop)에 마우스가 진입했을 때 (닫기 취소)
 */
this.menTop_onmouseenter = function(obj:nexacro.Menu, e:nexacro.MouseEventInfo)
{
    this.killTimer(99); // 하위 메뉴로 이동했으므로 닫지 않음
};

/**
 * @description 하위 팝업메뉴(menTop)에서 마우스가 완전히 벗어났을 때 (다시 닫기 예약)
 */
this.menTop_onmouseleave = function(obj:nexacro.Menu, e:nexacro.MouseEventInfo)
{
    this.setTimer(99, 300); // 하위 메뉴에서도 나가면 0.3초 후 닫음
};

/**
 * @description 상세메뉴(하위 팝업)가 동적으로 열릴 때 발생하는 이벤트
 */
this.menTop_oninnerpopup = function(obj:nexacro.Menu, e:nexacro.InnerPopupEventInfo)
{
	// e.popupobj는 방금 화면에 뿅 하고 나타난 하위 상세메뉴 객체입니다.
	if (e.popupobj) {
		// 새로 열린 상세메뉴에도 동일한 마우스 인/아웃(숨바꼭질 및 닫기) 이벤트를 걸어줍니다.
		e.popupobj.addEventHandler("onmouseenter", this.menTop_onmouseenter, this);
		e.popupobj.addEventHandler("onmouseleave", this.menTop_onmouseleave, this);
	}
};

this.gfnIsNull = function (pvVal)
{
	if (new String(pvVal).valueOf() == "undefined") 
	{
		return true;
	}
	if (pvVal == null) 
	{
		return true;
	}
	if (("x" + pvVal == "xNaN") && (new String(pvVal.length).valueOf() == "undefined")) 
	{
		return true;
	}
	if (pvVal.length == 0) 
	{
		return true;
	}

	return false;
}
this.Button05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.zoomScale += 10; // 확대 (+10%)
	if (this.zoomScale > 200) this.zoomScale = 200; // 최대 배율 제한
    this.setZoomScale();
};

this.setZoomScale = function() {
	if (system.navigatorname == "nexacro")
	{
		nexacro.setWheelZoom( this.getOwnerFrame(), this.zoomScale) // 화면 배율 변경
	}
	else
	{
		//document.body.style.zoom = this.zoomScale / 100; // 화면 배율 변경
		//var scale = this.zoomScale;//`${window.devicePixelRatio}`+; 
		//var scale =  `${window.devicePixelRatio}`; 
		nexacro.setWheelZoom(nexacro.getApplication().mainframe, this.zoomScale);
	}
    trace("현재 화면 배율: " + (this.zoomScale) + "%");
}

this.Button06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.zoomScale = 100; // 100%로 복원
    this.setZoomScale();
};


]]></Script>
  </Form>
</FDL>
