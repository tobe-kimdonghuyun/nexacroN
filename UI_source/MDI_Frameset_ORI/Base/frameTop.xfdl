            <Col id="INNER_PARAM"/>
            <Col id="MENU_NAVI">|계약서관리|전자계약|일반 계약서 등록</Col>
            <Col id="PROG_FILE">COMGAA080</Col>
            <Col id="MENU_PWD_USE_YN">N</Col>
            <Col id="BTN_HELP_YN">0</Col>
          </Row>
          <Row>
            <Col id="MENU_ID">CL</Col>
            <Col id="PARENT_ID">0</Col>
            <Col id="TOP_PARENT_ID">CL</Col>
