<?xml version="1.0" encoding="utf-8" ?>
<raonkphoto>
  <license>
    <product_key>632LN-02PU-M2KD-60EJ8</product_key>
    <license_key_html5></license_key_html5>
  </license>
  <setting>
    <lang>ko-kr</lang>
    
    <toolbar use="1">
      <menu>open</menu>
      <menu>separator</menu>
      <menu>save</menu>
      <menu>separator</menu>
      <menu>history</menu>
      <menu>separator</menu>
      <menu>rotate</menu>
      <menu>separator</menu>
      <menu tool="crop,mosaic">select</menu>
      <menu>separator</menu>
      <menu>flip</menu>
      <menu>separator</menu>
      <menu>resize</menu>
      <menu unit="10%">size_in_decrease</menu>
      <menu>separator</menu>      
      <menu>tone</menu>
      <menu>filter</menu>
      <menu>separator</menu>
      <menu type="0" desc="type 1: 포토띄우는 window의 body태그 style을 제거함, type 0: 제거하지 않음">fullscreen</menu>
      <menu>separator</menu>
      <menu color="#000000" back_width="" back_height="" back_color="#ffffff" back_opacity="100" border_color="#000000" border_width="0" border_opacity="100">text</menu>
      <menu>separator</menu>
      <menu>align</menu>
    </toolbar>

    <right_menu>
      <!--<menu width="50" height="50" angle="0" back_color="#5B9BD5" back_opacity="100" border_color="#000000" border_width="1" border_opacity="100">figure</menu>
      <menu>emoticon</menu>
      <menu xml_url="raonkphoto.userimage.xml">addimage</menu>-->
    </right_menu>

    <resize_select_menu use="1">
      <value desc="사이즈|기준, 기준값: w=가로, h=세로, l=긴축">200|w</value>
      <value>300|w</value>
      <value>1300|w</value>
      <value>400|h</value>
      <value>500|h</value>
      <value>300|l</value>
      <value>400|l</value>
      <value>1000|l</value>
      <value>auto</value>
    </resize_select_menu>

    <text_font_family>
      <font>굴림</font>
      <font>굴림체</font>
      <font>궁서</font>
      <font>궁서체</font>
      <font>돋움</font>
      <font>돋움체</font>
      <font default="">맑은 고딕</font>
      <font>바탕</font>
      <font>Arial</font>
      <font>Tahoma</font>
    </text_font_family>

    <text_font_size>
      <size>9</size>
      <size>10</size>
      <size>11</size>
      <size>12</size>
      <size>13</size>
      <size default="">14</size>
      <size>15</size>
      <size>16</size>
      <size>17</size>
      <size>18</size>
      <size>19</size>
      <size>20</size>
    </text_font_size>

    <statusbar use="0"></statusbar>
    
    <size width="800px" height="600px" desc="% or px"></size>

    <default_zIndex></default_zIndex>

    <visibility>show</visibility>

    <title></title>

    <filter>
      <item>vintage</item>
      <item>blur</item>
      <item>grayscale</item>
      <item>sepia</item>
    </filter>

    <canvas>
      <default_image_type quality="0.7">jpeg</default_image_type>  
    </canvas>

    <save method="upload" desc="upload or base64" get_text="1" desc2="get_text: 1이면 사용자가 넣은 text값도 함께 리턴받을 수 있음">
      <upload overwrite="0">
        <develop_langage desc=".NET(C#, ASP): NET, JAVA(JSP): JSP">JSP</develop_langage>
        <handler_url></handler_url>
        <foldername_rule></foldername_rule>
        <filename_rule duplication_character="i">GUID</filename_rule>
        <server_domain></server_domain>
      </upload>
    </save>

    <event></event>
  </setting>
</raonkphoto>  